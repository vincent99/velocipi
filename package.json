{
  "name": "velocipi",
  "version": "1.0.0",
  "description": "This runs on a Raspberry Pi 5 to control the screens, cameras, joysticks, audio, and various other toys in my Velocity V-Twin-6 N711ME.  I don't know why you're here, but good luck.",
  "homepage": "https://github.com/vincent99/velocipi#readme",
  "bugs": {
    "url": "https://github.com/vincent99/velocipi/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vincent99/velocipi.git"
  },
  "license": "Apache-2.0",
  "author": "",
  "type": "commonjs",
  "main": "ui/src/main.ts",
  "scripts": {
    "dev": "VELOCIPI_PORT=8081 concurrently --kill-others \"yarn dev:go\" \"yarn dev:ui\"",
    "dev:ui": "cd ui && yarn dev --host 0.0.0.0",
    "dev:go": "VELOCIPI_PORT=8081 air",
    "build": "yarn build:ui && go build -o velocipi ./server",
    "build:ui": "cd ui && yarn build",
    "build:go": "go build -o velocipi ./server",
    "musicsync": "go run ./cmd/musicsync",
    "thumbnails": "go run ./cmd/thumbnails"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "d3": "^7.9.0"
  }
}
